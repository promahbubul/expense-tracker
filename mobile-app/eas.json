{
  "cli": {
    "version": ">= 16.16.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://expense-tracker-api.rsitlink.com/api",
        "EXPO_PUBLIC_CURRENCY": "BDT"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://expense-tracker-api.rsitlink.com/api",
        "EXPO_PUBLIC_CURRENCY": "BDT"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
