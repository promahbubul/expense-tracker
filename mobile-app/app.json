{
  "expo": {
    "name": "Expense Tracker",
    "slug": "expense-tracker-mobile",
    "version": "0.1.0",
    "icon": "./src/assets/logo.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "expensetracker",
    "assetBundlePatterns": [
      "src/assets/logo.png"
    ],
    "splash": {
      "image": "./src/assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./src/assets/logo.png",
      "bundleIdentifier": "com.rsitlink.expensetracker"
    },
    "android": {
      "package": "com.rsitlink.expensetracker",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-sharing",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "0ba4ab14-5ee8-474a-82ff-69cefaa8fc22"
      }
    },
    "owner": "promahbubul"
  }
}
