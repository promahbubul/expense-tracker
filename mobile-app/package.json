{
  "name": "expense-tracker-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "start:lan": "expo start --lan --clear",
    "start:tunnel": "expo start --tunnel --clear",
    "start:localhost": "expo start --localhost --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor": "expo-doctor",
    "export:android": "expo export --platform android --output-dir dist --no-bytecode",
    "build:android:preview": "npx eas build --platform android --profile preview",
    "build:android:production": "npx eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.10",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "expo": "^55.0.17",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-print": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-server-api": "^20.1.3",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.14",
    "typescript": "^5.7.3"
  }
}
